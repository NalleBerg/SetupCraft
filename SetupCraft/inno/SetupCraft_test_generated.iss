[Code]
// Manually manage the setup mutex so we can show a custom localised message
// instead of Inno's built-in generic English dialog.
// If the user confirms, we try to find and close the running installer window.
function WinCreateMutex(lpAttr: Cardinal; bOwner: Boolean; lpName: String): Cardinal;
  external 'CreateMutexW@kernel32.dll stdcall';
function WinCloseHandle(h: Cardinal): Boolean;
  external 'CloseHandle@kernel32.dll stdcall';
function WinGetLastError(): Cardinal;
  external 'GetLastError@kernel32.dll stdcall';
function FindSetupWindow(lpClassName: Cardinal; lpWindowName: String): Cardinal;
  external 'FindWindowW@user32.dll stdcall';
function PostCloseMessage(hWnd: Cardinal; Msg: Cardinal; wParam: Cardinal; lParam: Cardinal): Boolean;
  external 'PostMessageW@user32.dll stdcall';

const
  ERROR_ALREADY_EXISTS = 183;
  WM_CLOSE       = 16;
  GWL_STYLE      = -16;
  PBS_SMOOTH     = 1;

var
  g_hSetupMutex: Cardinal;

function InitializeSetup(): Boolean;
var
  err: Cardinal;
  res: Integer;
  hWnd: Cardinal;
begin
  g_hSetupMutex := WinCreateMutex(0, True, 'Global\4C3541FD-A3BB-41D6-B9B5-96D56BAA5CE9_Setup');
  err := WinGetLastError();
  if (g_hSetupMutex <> 0) and (err = ERROR_ALREADY_EXISTS) then
  begin
    WinCloseHandle(g_hSetupMutex);
    g_hSetupMutex := 0;
    res := MsgBox(CustomMessage('mutex_message'), mbError, MB_YESNOCANCEL);
    if res = IDYES then
    begin
      hWnd := FindSetupWindow(0, 'SetupCraft Setup');
      if hWnd <> 0 then
        PostCloseMessage(hWnd, WM_CLOSE, 0, 0);
      Sleep(1500);
      g_hSetupMutex := WinCreateMutex(0, True, 'Global\4C3541FD-A3BB-41D6-B9B5-96D56BAA5CE9_Setup');
      err := WinGetLastError();
      if (g_hSetupMutex <> 0) and (err = ERROR_ALREADY_EXISTS) then
      begin
        WinCloseHandle(g_hSetupMutex);
        g_hSetupMutex := 0;
        Result := False;
      end else
        Result := True;
    end else
      Result := False;
  end else
    Result := True;
end;

function GetWindowLong(hWnd: LongInt; nIndex: Integer): LongInt;
  external 'GetWindowLongW@user32.dll stdcall';
function SetWindowLong(hWnd: LongInt; nIndex: Integer; dwNewLong: LongInt): LongInt;
  external 'SetWindowLongW@user32.dll stdcall';

function GetTickCount_SC: Cardinal;
  external 'GetTickCount@kernel32.dll stdcall';

var
  g_InstallStart_SC: Cardinal;
  g_EtaLabel_SC: TLabel;
  WelcomePage_SC: TWizardPage;
  WelcomeViewer_SC: TRichEditViewer;

procedure CreateWelcomePage_SC; forward;

procedure InitializeWizard;
begin
  SetWindowLong(WizardForm.ProgressGauge.Handle, GWL_STYLE,
    GetWindowLong(WizardForm.ProgressGauge.Handle, GWL_STYLE) or PBS_SMOOTH);
  g_EtaLabel_SC := TLabel.Create(WizardForm);
  g_EtaLabel_SC.Parent := WizardForm.InstallingPage;
  g_EtaLabel_SC.AutoSize := False;
  g_EtaLabel_SC.Left   := WizardForm.ProgressGauge.Left;
  g_EtaLabel_SC.Top    := WizardForm.ProgressGauge.Top + WizardForm.ProgressGauge.Height + 4;
  g_EtaLabel_SC.Width  := WizardForm.ProgressGauge.Width;
  g_EtaLabel_SC.Caption := '';
  WizardForm.DirEdit.ReadOnly := True;
  WizardForm.DirBrowseButton.Enabled := False;
  CreateWelcomePage_SC;
end;

procedure CurInstallProgressChanged(CurProgress, MaxProgress: Integer);
var
  Elapsed, Remaining: Cardinal;
  RemainSec: Integer;
  Pct: Double;
begin
  if CurProgress = 0 then
  begin
    g_InstallStart_SC := GetTickCount_SC;
    if Assigned(g_EtaLabel_SC) then
      g_EtaLabel_SC.Caption := 'Calculating time remaining...';
    Exit;
  end;
  if (MaxProgress <= 0) then Exit;
  Elapsed := GetTickCount_SC - g_InstallStart_SC;
  if Elapsed < 1000 then Exit;
  Pct := CurProgress / MaxProgress;
  if Pct <= 0 then Exit;
  Remaining := Round(Elapsed / Pct) - Elapsed;
  RemainSec := Remaining div 1000;
  if RemainSec < 0 then RemainSec := 0;
  if Assigned(g_EtaLabel_SC) then
    g_EtaLabel_SC.Caption := 'Time remaining: '
      + IntToStr(RemainSec div 60) + ' min '
      + IntToStr(RemainSec mod 60) + ' sec';
end;


procedure CreateWelcomePage_SC;
var
  WelcomeImage_SC: TBitmapImage;
begin
  WelcomePage_SC := CreateCustomPage(wpWelcome, 'Welcome', '');
  ExtractTemporaryFile('SetupCraft_test_generated_welcome_preview.png');
  WelcomeImage_SC := TBitmapImage.Create(WelcomePage_SC);
  WelcomeImage_SC.Parent := WelcomePage_SC.Surface;
  WelcomeImage_SC.AutoSize := True;
  WelcomeImage_SC.PngImage.LoadFromFile(ExpandConstant('{tmp}\SetupCraft_test_generated_welcome_preview.png'));
  WelcomeImage_SC.Left := (WelcomePage_SC.SurfaceWidth - WelcomeImage_SC.Width) div 2;
  WelcomeImage_SC.Top := ScaleY(56);
  WelcomeViewer_SC := TRichEditViewer.Create(WelcomePage_SC);
  WelcomeViewer_SC.Parent := WelcomePage_SC.Surface;
  WelcomeViewer_SC.Left := 0;
  WelcomeViewer_SC.Top := 0;
  WelcomeViewer_SC.Width := WelcomePage_SC.SurfaceWidth;
  WelcomeViewer_SC.Height := WelcomePage_SC.SurfaceHeight;
  WelcomeViewer_SC.BevelKind := bkFlat;
  WelcomeViewer_SC.BorderStyle := bsNone;
  WelcomeViewer_SC.ReadOnly := True;
  WelcomeViewer_SC.ScrollBars := ssVertical;
  WelcomeViewer_SC.UseRichEdit := True;
  WelcomeViewer_SC.RTFText := '{\rtf1\ansi\ansicpg1252\deff0\nouicompat{\fonttbl{\f0\fswiss\fcharset0 Arial;}{\f1\fnil Segoe UI;}}{\*\generator Riched20 10.0.26100}\viewkind4\uc1 \pard\sb120\qc\b\f0\fs28\lang1044 Welcome to SetupCraft, V. 2026.05.29.14\par\b0\f1\fs24{\pict{\*\picprop{\sp{\sn wzDescription}{\sv Image}}{\sp{\sn posv}{\sv 1}}}\pngblip\picw6773\pich6773\picwgoal3840\pichgoal3840 }\f0\fs20 ''\par\pard\sb120 Thank you for choosing StupCraft. I hope it will suit your needs.\par}';
end;

function UpdateReadyMemo(Space, NewLine, MemoUserInfoInfo, MemoDirInfo, MemoTypeInfo, MemoComponentsInfo, MemoGroupInfo, MemoTasksInfo: String): String;
var
  Drive: String;
  FreeMB, TotalMB: Cardinal;
begin
  Result := '';
  if MemoUserInfoInfo <> '' then Result := Result + MemoUserInfoInfo + NewLine + NewLine;
  if MemoDirInfo <> '' then Result := Result + MemoDirInfo + NewLine + NewLine;
  if MemoTypeInfo <> '' then Result := Result + MemoTypeInfo + NewLine + NewLine;
  if MemoComponentsInfo <> '' then Result := Result + MemoComponentsInfo + NewLine + NewLine;
  if MemoGroupInfo <> '' then Result := Result + MemoGroupInfo + NewLine + NewLine;
  if MemoTasksInfo <> '' then Result := Result + MemoTasksInfo + NewLine + NewLine;
  Drive := ExtractFileDrive(WizardDirValue());
  GetSpaceOnDisk(Drive, True, FreeMB, TotalMB);
  Result := Result + 'Disk space required:  0 MB' + NewLine;
  Result := Result + 'Disk space available (' + Drive + '): ' + IntToStr(FreeMB) + ' MB';
end;


{ Component dependency enforcement (generated by SetupCraft) }
function GetCompIdx_SC(const Desc: String): Integer;
var I: Integer;
begin
  Result := -1;
  for I := 0 to WizardForm.ComponentsList.Items.Count - 1 do
    if CompareText(WizardForm.ComponentsList.Items[I], Desc) = 0 then
    begin
      Result := I;
      Exit;
    end;
end;

procedure EnforceCompDeps_SC;
var IdxA, IdxB: Integer;
begin
end;

procedure OnCompListClickCheck_SC(Sender: TObject);
begin
  EnforceCompDeps_SC;
end;

procedure CurPageChanged(CurPageID: Integer);
begin
  if CurPageID = wpSelectComponents then
    WizardForm.ComponentsList.OnClickCheck := @OnCompListClickCheck_SC;
  if Assigned(WelcomePage_SC) then
    WizardForm.WizardSmallBitmapImage.Visible := CurPageID <> WelcomePage_SC.ID;
end;



procedure DeinitializeSetup();
begin
  if g_hSetupMutex <> 0 then
  begin
    WinCloseHandle(g_hSetupMutex);
    g_hSetupMutex := 0;
  end;
  
end;
